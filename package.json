{
  "name": "ttt-monorepo",
  "version": "1.0.0",
  "packageManager": "pnpm@10.29.2",
  "private": true,
  "scripts": {
    "test": "turbo run test",
    "dev:client": "pnpm --filter client dev",
    "dev:websocket": "pnpm --filter websocket dev",
    "build:client": "pnpm --filter client build",
    "build:websocket": "pnpm --filter websocket build",
    "generate:contract": "pnpm --filter contract generate",
    "install:all": "pnpm install",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "release": "changeset publish",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "turbo": "latest",
    "typescript-eslint": "^8.61.0"
  },
  "pnpm": {
    "overrides": {
      "fdir": "^6.4.3"
    }
  }
}
