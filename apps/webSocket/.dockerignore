# =========================================================
# 1. Node.js 관련 제외 항목 (로컬 종속성 및 캐시)
# =========================================================

# 로컬에 설치된 node_modules 폴더 전체를 제외합니다.
# 컨테이너 내에서 'npm install'을 통해 새로 설치되어야 합니다.
node_modules

# npm/yarn 캐시 및 로그 파일
npm-debug.log
yarn-error.log
.npm

# =========================================================
# 2. 시스템 및 개발 관련 파일 제외
# =========================================================

# Git 버전 관리 파일
.git
.gitignore

# IDE 및 OS 관련 메타데이터 파일
.vscode
.idea
*.sublime-project
*.sublime-workspace
.DS_Store

# =========================================================
# 3. 환경 설정 및 임시 파일 제외
# =========================================================

# 환경 변수 설정 파일 (보안 및 환경 독립성을 위해 제외)
.env
.env.*

# 빌드 및 배포 과정에서 생성되는 임시 또는 출력 폴더 (필요시)
dist
build
tmp
temp