else
  export NODE_PATH="/mnt/e/JS/project_ttt/client/node_modules/.pnpm/vitest@4.1.8_@types+node@25_8de1004c6ce04d4f919ddf3ea15f881c/node_modules/vitest/node_modules:/mnt/e/JS/project_ttt/client/node_modules/.pnpm/vitest@4.1.8_@types+node@25_8de1004c6ce04d4f919ddf3ea15f881c/node_modules:/mnt/e/JS/project_ttt/client/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../vitest/vitest.mjs" "$@"
else
  exec node  "$basedir/../vitest/vitest.mjs" "$@"
fi
