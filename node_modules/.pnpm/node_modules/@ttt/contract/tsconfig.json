{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["dist/index.ts", "dist/rest-api.types.ts", "dist/socket-client-events.types.ts", "dist/socket-server-events.types.ts"],
  "exclude": []
}
