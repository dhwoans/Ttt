# =========================================================
# 1. 빌드 환경 설정
# =========================================================

# Node.js 20 버전의 Alpine Linux 경량 이미지를 기반으로 사용합니다.
FROM node:20-alpine

# 컨테이너 내부의 작업 디렉터리를 /app으로 설정합니다.
WORKDIR /app

# =========================================================
# 2. 종속성 설치 (캐싱 활용)
# =========================================================

# package.json과 package-lock.json 파일만 먼저 복사합니다.
# 이 파일들이 변경되지 않으면 'npm install' 레이어를 재사용하여 빌드 시간을 단축합니다.
COPY package*.json ./

# 필요한 모든 Node.js 종속성(node_modules)을 설치합니다.
RUN npm install

# =========================================================
# 3. 애플리케이션 코드 복사 및 실행
# =========================================================

# 개발 환경에서 불필요한 파일/폴더(예: node_modules)를 복사하지 않도록
# .dockerignore 파일을 사용하세요.
# 나머지 모든 소스 코드를 작업 디렉터리로 복사합니다.
COPY . .

# 애플리케이션이 사용할 포트를 외부에 알립니다.
EXPOSE 3000

# 컨테이너가 시작될 때 실행될 명령어입니다. 
# Node.js 서버를 실행합니다.
CMD ["npm", "start"]