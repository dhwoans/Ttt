{
  "name": "@ttt/contract",
  "version": "1.0.0",
  "description": "Shared API and Socket types for Tic Tac Toe",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "*.yaml",
    "paths",
    "schemas"
  ],
  "scripts": {
    "build": "pnpm run generate && tsc",
    "generate": "openapi-typescript ./openapi.yaml -o ./src/generated/rest-api.types.ts && openapi-typescript ./socket-client-events.yaml -o ./src/generated/socket-client-events.types.ts && openapi-typescript ./socket-server-events.yaml -o ./src/generated/socket-server-events.types.ts"
  },
  "devDependencies": {
    "openapi-typescript": "^7.0.0",
    "typescript": "^5.0.0"
  }
}
